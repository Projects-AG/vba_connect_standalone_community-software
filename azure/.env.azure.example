# Architecture: Azure App Service (backend + frontend compose) + Hostinger VPS (LiveKit)
# Copy to .env.azure and set URLs before rebuild.

AZURE_WEB_URL=https://YOUR-WEB-APP.azurewebsites.net
AZURE_API_URL=https://YOUR-WEB-APP.azurewebsites.net

VITE_API_URL=
VITE_LIVEKIT_URL=wss://YOUR_VPS_IP_OR_DOMAIN

PORT=8080
CORS_ORIGINS=https://YOUR-WEB-APP.azurewebsites.net
LIVEKIT_HOST=http://YOUR_VPS_IP_OR_DOMAIN:7880
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

DOCKERHUB_USER=projectsag
BACKEND_IMAGE=projectsag/project-loop-backend:latest
FRONTEND_IMAGE=projectsag/project-loop:latest
