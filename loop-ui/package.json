{
  "name": "@projects-ag/loop-ui",
  "version": "0.2.0",
  "description": "LOOP meeting UI kit (Fluent Velocity) — integrable PreCall, VideoTile, ControlBar, and Nest/LiveKit helpers",
  "type": "module",
  "license": "UNLICENSED",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/loop-ui.cjs",
  "module": "./dist/loop-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/loop-ui.js",
      "require": "./dist/loop-ui.cjs"
    },
    "./styles.css": "./dist/loop-ui.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:lib": "tsc --noEmit && vite build --config vite.config.lib.ts",
    "prepublishOnly": "npm run build:lib",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "livekit-client": "^2.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "livekit-client": {
      "optional": true
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.3",
    "framer-motion": "^12.23.12"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^9.1.2",
    "@storybook/addon-docs": "^9.1.2",
    "@storybook/react-vite": "^9.1.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "livekit-client": "^2.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "storybook": "^9.1.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^4.5.4"
  },
  "keywords": [
    "loop",
    "ui-kit",
    "video",
    "livekit",
    "react",
    "fluent-velocity"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/example/loop-ui.git"
  }
}
