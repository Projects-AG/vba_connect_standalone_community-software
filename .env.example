# Copy to .env if you want to override compose defaults (optional).
# Browser-facing URLs must use localhost (or your host IP), not Docker service names.

PORT=3000
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

LIVEKIT_HOST=http://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=myverylongsecretkey12345678901234567890

JWT_SECRET=project-loop-dev-secret-change-me
JWT_EXPIRES_IN=7d

# MySQL (backend). For Docker Compose on Windows/Mac use host.docker.internal
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=loop_db
DB_SYNC=true

# Build args for frontend (set in docker-compose.yml by default)
VITE_API_URL=
VITE_LIVEKIT_URL=ws://localhost:7880
